    { "id": "e11", "from": "n15", "to": "n2", "label": "喂回结果，下一轮 turn", "variant": "dashed", "role": "return", "fromSide": "left", "toSide": "bottom", "via": [[520, 243], [520, 320], [220, 320]], "labelSegment": 1, "labelDy": 40 },
    { "id": "e12", "from": "n15", "to": "n18", "label": "shouldStop=true", "variant": "emphasis", "fromSide": "top", "toSide": "bottom", "route": "drop" }
