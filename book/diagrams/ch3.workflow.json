  "cards": [
    { "dot": "cyan", "title": "两层循环", "items": ["内层 turn：流式回复→执行工具→回填结果", "外层 run：内层收尾后判定要不要 follow-up 续跑"] },
    { "dot": "emerald", "title": "先看停止原因", "items": ["length：给残缺调用造错误结果后 continue 重试", "end_turn/tool_use：看是否点名工具决定收尾还是执行"] },
    { "dot": "rose", "title": "唯一出口", "items": ["error/aborted、全 terminate、shouldStop、无 follow-up", "多条终止路径都汇到同一个 finish：算新消息+agent_end+Close"] }
